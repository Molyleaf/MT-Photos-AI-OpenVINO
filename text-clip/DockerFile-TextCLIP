FROM python:3.12-slim-trixie

WORKDIR /app

ARG DEBIAN_FRONTEND=noninteractive
ARG APP_UID=1000
ARG APP_GID=1000

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_INDEX_URL=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple \
    PIP_TRUSTED_HOST=mirrors.tuna.tsinghua.edu.cn \
    MODEL_PATH=/models \
    OV_CACHE_DIR=/cache/openvino \
    PORT=8061

RUN rm -f /etc/apt/sources.list \
    && rm -rf /etc/apt/sources.list.d/*

COPY sources.list /etc/apt/sources.list

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        libglib2.0-0 \
        libgomp1

COPY text-clip/requirement.txt /tmp/requirement.txt

RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    set -eux; \
    pip install --cache-dir /root/.cache/pip --prefer-binary -r /tmp/requirement.txt; \
    rm -f /tmp/requirement.txt

RUN set -eux; \
    groupadd --gid "${APP_GID}" appgroup; \
    useradd --uid "${APP_UID}" --gid "${APP_GID}" --create-home --shell /usr/sbin/nologin appuser; \
    mkdir -p /cache/openvino /models/qa-clip/openvino /app/models/QA-CLIP/clip; \
    chmod -R 777 /cache; \
    chown -R appuser:appgroup /app /models /cache

COPY --chown=appuser:appgroup models/qa-clip/openvino/openvino_text_fp16.xml /models/qa-clip/openvino/openvino_text_fp16.xml
COPY --chown=appuser:appgroup models/qa-clip/openvino/openvino_text_fp16.bin /models/qa-clip/openvino/openvino_text_fp16.bin
COPY --chown=appuser:appgroup app/models/QA-CLIP/clip/bert_tokenizer.py /app/models/QA-CLIP/clip/bert_tokenizer.py
COPY --chown=appuser:appgroup app/models/QA-CLIP/clip/vocab.txt /app/models/QA-CLIP/clip/vocab.txt
COPY --chown=appuser:appgroup text-clip/app /app

RUN set -eux; \
    test -f /models/qa-clip/openvino/openvino_text_fp16.xml; \
    test -f /models/qa-clip/openvino/openvino_text_fp16.bin; \
    test -f /app/models/QA-CLIP/clip/bert_tokenizer.py; \
    test -f /app/models/QA-CLIP/clip/vocab.txt

USER appuser

EXPOSE 8061

HEALTHCHECK --interval=30s --timeout=5s --start-period=40s --retries=3 \
    CMD sh -c "python -c \"import os, urllib.request; urllib.request.urlopen('http://127.0.0.1:' + os.environ.get('PORT', '8061') + '/', timeout=3)\" || exit 1"

CMD ["sh", "-c", "uvicorn server:app --host 0.0.0.0 --port ${PORT:-8061} --log-level ${LOG_LEVEL:-warning}"]
